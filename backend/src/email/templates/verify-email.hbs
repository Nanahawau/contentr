<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>
<body style="margin:0;padding:0;background:#fafaf9;font-family:'Inter',Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="padding:40px 0;">
    <tr>
      <td align="center">

        <!-- Logo -->
        <p style="margin:0 0 24px;font-size:18px;font-weight:600;color:#1c1917;">Contentr</p>

        <!-- Card -->
        <table width="480" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:12px;padding:40px;border:1px solid #e7e5e4;">
          <tr>
            <td>
              <h1 style="margin:0 0 12px;font-size:20px;font-weight:600;color:#1c1917;">Verify your email</h1>
              <p style="margin:0 0 28px;font-size:14px;color:#57534e;line-height:1.6;">
                Thanks for signing up for Contentr. Click the button below to verify your email address.
                This link expires in <strong>30 minutes</strong>.
              </p>
              <a href="{{verificationUrl}}"
                 style="display:inline-block;padding:12px 24px;background:#1c1917;color:#ffffff;border-radius:6px;text-decoration:none;font-size:14px;font-weight:500;">
                Verify email
              </a>
              <hr style="margin:32px 0;border:none;border-top:1px solid #e7e5e4;" />
              <p style="margin:0;font-size:12px;color:#a8a29e;">
                If you didn't create a Contentr account, you can safely ignore this email.
              </p>
            </td>
          </tr>
        </table>

      </td>
    </tr>
  </table>
</body>
</html>