# App
PORT=3000
PROVIDER_MODE=local

# MongoDB (local)
MONGO_URL=mongodb://localhost:27017/contentr
MONGO_PORT=27017

# Redis (local)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=local-dev-secret
JWT_EXPIRY=24hr

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_ACCESS_SECRET=
GOOGLE_CALLBACK_URL=

# MinIO (local S3)
AWS_ENDPOINT=http://localhost:9000
REGION=us-east-1
BUCKET_NAME=contentr-media
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_KEY_ID=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Local Whisper
LOCAL_WHISPER_URL=http://localhost:9002/v1
LOCAL_WHISPER_PORT=9002
WHISPER_MODEL=base

# Ollama
LOCAL_OLLAMA_URL=http://localhost:11434/v1
LOCAL_OLLAMA_MODEL=llama3
OLLAMA_PORT=11434

# Email (local — Mailpit)
EMAIL_PROVIDER_MODE=smtp
SMTP_HOST=mailpit
SMTP_PORT=1025
